# Copy this to scripts/.env.local (gitignored) and fill in real values.
# The PS scripts in this directory auto-load it.
#
# Get the URL from Supabase Dashboard -> Project Settings -> Database ->
# Connection string -> URI (Direct connection, not pooler). The password is
# the DB password (separate from your Supabase account login). Reset it on
# the same page if you forgot it or if it's been exposed.

PROD_DB_URL=postgresql://postgres:REPLACE_WITH_PASSWORD@db.REPLACE_WITH_REF.supabase.co:5432/postgres
