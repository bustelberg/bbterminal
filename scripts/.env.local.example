# Copy this to scripts/.env.local (gitignored) and fill in real values.
# The PS scripts in this directory auto-load it.
#
# Get the URL from Supabase Dashboard -> Project Settings -> Database ->
# Connection string -> "Session pooler" tab. Format below. Notes:
#   * Use the "Session pooler" tab, NOT "Direct connection" (IPv6-only,
#     Docker on Windows can't reach it) and NOT "Transaction pooler"
#     (port 6543 rejects the DDL these scripts run).
#   * Username is "postgres.<project-ref>" — different from the direct
#     connection's plain "postgres".
#   * Password is the DB password, separate from your Supabase login.
#     Reset on the same page if it's been exposed.

PROD_DB_URL=postgresql://postgres.REPLACE_WITH_REF:REPLACE_WITH_PASSWORD@aws-0-REPLACE_WITH_REGION.pooler.supabase.com:5432/postgres
